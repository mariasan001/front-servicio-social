# Origen del backend Java (proxy de Next.js) — obligatorio en producción
API_PROXY_TARGET=http://localhost:8080

# Base URL para peticiones del navegador (auth y formularios cliente)
NEXT_PUBLIC_API_URL=/api/backend

# URL pública del sitio (SEO, sitemap, enlaces de invitación)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry (opcional). Si está vacío, los errores solo van a consola.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

# Credenciales E2E del panel (opcionales). Sin ellas, los smokes por rol se omiten.
# E2E_ADMIN_USER=
# E2E_ADMIN_PASSWORD=
# E2E_ALUMNO_USER=
# E2E_ALUMNO_PASSWORD=
# E2E_DELEGACION_USER=
# E2E_DELEGACION_PASSWORD=
# E2E_TITULAR_USER=
# E2E_TITULAR_PASSWORD=
# E2E_ENLACE_USER=
# E2E_ENLACE_PASSWORD=
