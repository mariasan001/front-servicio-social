# Origen del backend Java (proxy de Next.js) — obligatorio en producción
API_PROXY_TARGET=http://localhost:8080

# Base URL para peticiones del navegador (auth y formularios cliente)
NEXT_PUBLIC_API_URL=/api/backend

# URL pública del sitio (SEO, sitemap, enlaces de invitación)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
